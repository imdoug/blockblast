{
  "expo": {
    "name": "BloxBurst",
    "slug": "blockblast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
   "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2A4A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.makewondr.bloxburst",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.makewondr.bloxburst",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1B2A4A"
      }
    },
    "scheme": "bloxburst",
    "plugins": [
      "expo-router",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-4649688048415899~5057012442"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "We show ads to keep BloxBurst free. Your data is never sold."
        }
      ],
      "expo-asset"
    ],
    "updates": {
      "enabled": false
    },
    "extra": {
      "privacyPolicyUrl": "https://imdoug.github.io/bloxburst-privacy/",
      "router": {},
      "eas": {
        "projectId": "e3480e30-b7f8-4e67-894b-69a1016e1474"
      }
    },
    "owner": "imdoug"
  }
}
